{
    "netuid": 3,
    "burn_rate": 1.0,
    "burn_uid": 3,

    "evaluation_runs": 2,
    "eval_steps": 20,
    "eval_timeout": 3600,
    "min_success_rate": 0.3,

    "benchmark_model_name": "Qwen/Qwen2.5-7B",
    "benchmark_tokenizer_name": "google/gemma-3-27b-it",
    "benchmark_dataset_name": "HuggingFaceFW/fineweb",
    "benchmark_dataset_split": "train",
    "benchmark_data_samples": 10000,
    "benchmark_master_seed": 42,
    "benchmark_sequence_length": 1024,
    "benchmark_batch_size": 16,

    "set_weights_interval_blocks": 5,
    "reveal_blocks": 1,
    "min_blocks_between_commits": 1,
    "block_time": 12,

    "docker": {
        "num_gpus": 4,
        "memory_limit": "320g",
        "shm_size": "64g"
    },

    "basilica": {
        "image": "ghcr.io/one-covenant/templar-eval:latest",
        "ttl_seconds": 7200,
        "gpu_count": 4,
        "gpu_models": ["A100"],
        "min_gpu_memory_gb": 80,
        "interconnect": "SXM",
        "cpu": "16",
        "memory": "320Gi"
    },

    "verification": {
        "max_loss_difference": 0.4,
        "min_params_changed_ratio": 0.75,
        "weight_relative_error_max": 0.015,
        "timer_divergence_threshold": 0.005
    },

    "mfu": {
        "gpu_peak_tflops": 312.0,
        "max_plausible_mfu": 85.0,
        "min_mfu": 50.0
    },

    "adaptive_threshold": {
        "base_threshold": 0.01,
        "decay_percent": 0.05,
        "decay_interval_blocks": 100
    },

    "code_fetch_timeout": 30,
    "max_evaluated_urls": 10000,

    "payment": {
        "enabled": true,
        "fee_rao": 50000000,
        "payment_address": "",
        "rpc_timeout": 30,
        "rpc_retries": 2
    }
}
