# LLM Provider — choose one: "chutes", "openrouter", or "anthropic"
LLM_PROVIDER=chutes

# Set the API key for your chosen provider (only one needed):
# Chutes:      CHUTES_API_KEY=your-key
# OpenRouter:  OPENROUTER_API_KEY=your-key
# Anthropic:   ANTHROPIC_API_KEY=your-key

# Optional: override the default model for your provider
# LLM_MODEL=deepseek-ai/DeepSeek-R1-0528-TEE

# Optional: LLM sampling temperature (default: 0.6)
# Higher = more creative/diverse, lower = more deterministic
# LLM_TEMPERATURE=0.8

# Basilica — remote GPU testing
BASILICA_API_TOKEN=
